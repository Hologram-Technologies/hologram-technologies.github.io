      "prefLabel": "Asset Assessment",
      "hospm:realizedBy": "usr/lib/holo/holo-atlas.js",
      "hospm:obligation": "Inventory what you already have to reuse (Law L3 dedup): the κ corpus mapped by Holo Atlas."
    },
    {
