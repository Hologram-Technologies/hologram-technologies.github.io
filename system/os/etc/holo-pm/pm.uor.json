  "hospm:activities": [
    {
      "@id": "hospm:market-problems",
      "broader": "hospm:market",
      "prefLabel": "Market Problems",
      "hospm:obligation": "Find the real, urgent, pervasive pain — the product exists to solve it (the bridge's input). NIHITO: evidence from the market, not the office."
    },
    {
      "@id": "hospm:win-loss-analysis",
      "broader": "hospm:market",
      "prefLabel": "Win/Loss Analysis",
      "hospm:obligation": "Learn from every won and lost deal why buyers chose or didn't — feed it back into Focus + Planning."
    },
    {
      "@id": "hospm:distinctive-competencies",
      "broader": "hospm:market",
      "prefLabel": "Distinctive Competencies",
      "hospm:realizedBy": "usr/lib/holo/holo-uor.mjs",
      "hospm:obligation": "Name the unfair advantage. Hologram's is the substrate: content-addressed, self-verifying, serverless (κ = H(content), Law L5) — time-to-value ≈ 0."
    },
    {
      "@id": "hospm:competitive-landscape",
      "broader": "hospm:market",
      "prefLabel": "Competitive Landscape",
      "hospm:obligation": "Know the alternatives (including 'do nothing'); position against them on the buyer's terms."
    },
    {
