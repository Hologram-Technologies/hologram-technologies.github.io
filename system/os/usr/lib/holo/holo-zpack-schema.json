{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "ADOPTED SPEC (ADR-0059) — vendored verbatim from zebar (github.com/glzr-io/zebar, resources/zpack-schema.json) as a byte-pinned, content-addressed κ-object. Hologram OS does NOT run zebar's Tauri runtime (Law / ADR-0029: never run a foreign runtime); it adopts zebar's widget-pack CONTRACT and renders the dock natively. holo-dock-config.json is a valid instance of this schema; tools/holo-dock-witness.mjs proves conformance.",
  "title": "Zebar widget pack",
  "description": "A widget pack for Zebar.",
  "type": "object",
  "required": ["name", "version", "widgets"],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "previewImages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repositoryUrl": {
      "type": "string"
    },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "htmlPath",
          "zOrder",
          "shownInTaskbar",
          "focused",
          "resizable",
          "transparent",
          "presets"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "htmlPath": {
            "type": "string"
          },
          "zOrder": {
            "type": "string",
            "enum": ["top_most", "normal", "bottom_most"]
          },
          "shownInTaskbar": {
            "type": "boolean"
          },
          "focused": {
            "type": "boolean"
          },
          "resizable": {
            "type": "boolean"
          },
          "transparent": {
            "type": "boolean"
          },
          "includeFiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "caching": {
            "type": "object",
            "properties": {
              "defaultDuration": {
                "type": "integer"
              },
              "rules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "urlRegex": {
                      "type": "string"
                    },
                    "duration": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "privileges": {
            "type": "object",
            "properties": {
              "shellCommands": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "program": {
                      "type": "string"
                    },
                    "argsRegex": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "presets": {
            "type": "array",
            "items": [
              {
                "type": "object",
                "required": [
                  "name",
                  "anchor",
                  "offsetX",
                  "offsetY",
                  "width",
                  "height",
                  "monitorSelection"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "anchor": {
                    "type": "string",
                    "enum": [
                      "top_left",
                      "top_center",
                      "top_right",
                      "center_left",
                      "center",
                      "center_right",
                      "bottom_left",
                      "bottom_center",
                      "bottom_right"
                    ]
                  },
                  "offsetX": {
                    "type": "string"
                  },
                  "offsetY": {
                    "type": "string"
                  },
                  "width": {
                    "type": "string"
                  },
                  "height": {
                    "type": "string"
                  },
                  "monitorSelection": {
                    "type": "object",
                    "oneOf": [
                      {
                        "properties": {
                          "type": {
                            "const": "all"
                          }
                        },
                        "required": ["type"],
                        "additionalProperties": false
                      },
                      {
                        "properties": {
                          "type": {
                            "const": "primary"
                          }
                        },
                        "required": ["type"],
                        "additionalProperties": false
                      },
                      {
                        "properties": {
                          "type": {
                            "const": "secondary"
                          }
                        },
                        "required": ["type"],
                        "additionalProperties": false
                      },
                      {
                        "properties": {
                          "type": {
                            "const": "index"
                          },
                          "match": {
                            "type": "integer",
                            "minimum": 0
                          }
                        },
                        "required": ["type", "match"],
                        "additionalProperties": false
                      },
                      {
                        "properties": {
                          "type": {
                            "const": "name"
                          },
                          "match": {
                            "type": "string"
                          }
                        },
                        "required": ["type", "match"],
                        "additionalProperties": false
                      }
                    ]
                  },
                  "dockToEdge": {
                    "type": "object",
                    "properties": {
                      "enabled": {
                        "type": "boolean",
                        "default": false
                      },
                      "edge": {
                        "oneOf": [
                          {
                            "type": "string",
                            "enum": ["top", "right", "bottom", "left"]
                          },
                          {
                            "type": "null"
                          }
                        ],
                        "default": null
                      },
                      "windowMargin": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  }
                }
              }
            ]
          }
        }
      }
    }
  }
}
