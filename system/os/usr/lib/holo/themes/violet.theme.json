      "ink": {
        "$value": "#fafafa",
        "$type": "color"
      },
      "ink-dim": {
        "$value": "#a1a1aa",
        "$type": "color"
      },
      "ink-subtle": {
        "$value": "#71717a",
        "$type": "color"
      },
      "accent": {
        "$value": "#a78bfa",
        "$type": "color"
      },
      "accent-ink": {
        "$value": "#ffffff",
        "$type": "color"
      },
      "ok": {
        "$value": "#22c55e",
        "$type": "color"
      },
      "warn": {
        "$value": "#f97316",
        "$type": "color"
      },
      "danger": {
        "$value": "#ef4444",
        "$type": "color"
      }
    }
  },
  "radius": {
    "sm": {
      "$value": "0.375rem",
      "$type": "dimension"
    },
    "md": {
      "$value": "0.75rem",
      "$type": "dimension"
    },
    "lg": {
      "$value": "1rem",
      "$type": "dimension"
    }
  },
  "font": {
    "family": {
      "sans": {
        "$value": "\"Helvetica Neue\", Helvetica, Arial, \"Segoe UI\", Roboto, system-ui, sans-serif",
        "$type": "fontFamily"
      },
      "serif": {
        "$value": "ui-serif, Georgia, \"Times New Roman\", serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "ui-monospace, \"Cascadia Code\", \"JetBrains Mono\", Menlo, Consolas, monospace",
        "$type": "fontFamily"
      }
    }
  }
}
