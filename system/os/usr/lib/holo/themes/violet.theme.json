        "$value": "#09090B",
        "$type": "color"
      },
      "surface": {
        "$value": "#111111",
        "$type": "color"
      },
      "surface-2": {
        "$value": "#18181b",
        "$type": "color"
      },
      "surface-emphasized": {
        "$value": "#27272a",
