{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Chakra neutrals with a violet accent.",
  "$extensions": {
    "org.hologram.theme": {
      "name": "Holo Violet"
    }
  },
  "color": {
    "light": {
      "bg": {
        "$value": "#fafafa",
        "$type": "color"
      },
      "surface": {
        "$value": "#FFFFFF",
