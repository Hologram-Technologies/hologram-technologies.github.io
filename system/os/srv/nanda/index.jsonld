      "skills": [
        {
          "id": "resolve_object",
          "description": "Resolve + verify this holospace as a self-verifying UOR object — re-derive its did:holo and confirm it (Law L5).",
          "inputModes": [
            "application/json"
          ],
          "outputModes": [
            "application/ld+json"
          ],
          "supportedLanguages": [
            "en"
          ]
        },
        {
          "id": "disclose_for_purpose",
          "description": "Produce a W3C Verifiable Presentation that discloses only the personal-data claims the user's standing policy authorizes for a given DPV purpose and recipient (selective disclosure). Returns null if nothing is authorized (default-deny). Args: purpose (dpv:…), recipient, claims:[{category,name}].",
          "inputModes": [
            "application/json"
          ],
          "outputModes": [
            "application/ld+json"
          ],
          "supportedLanguages": [
            "en"
          ]
        },
        {
          "id": "verify_disclosure",
          "description": "Verify a W3C Verifiable Presentation against its personal-data commitment: re-derive its content address (Law L5), verify the holder's data-integrity proof, and recompute every disclosed SD-JWT digest. Reports what was disclosed and how much (n of m). Args: presentation, commitment.",
          "inputModes": [
            "application/json"
          ],
          "outputModes": [
            "application/ld+json"
          ],
          "supportedLanguages": [
            "en"
          ]
        }
      ],
