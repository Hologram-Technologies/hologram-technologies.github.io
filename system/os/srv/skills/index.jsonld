      "dcterms:title": "Holo Skills — agentskills.io skills published by Hologram OS, each a self-verifying UOR object",
      "dcterms:source": "os/.well-known/mcp.json",
      "dcterms:conformsTo": "https://agentskills.io/specification",
      "skills": [
        {
          "name": "agreement-for",
          "description": "Return the signed agreement record for an app (the granted capabilities under the user's terms), or null. Args: appId.",
          "path": "skills/agreement-for/SKILL.md",
          "kappa": "sha256:6ebe937ff1040c7c09395659dadee0ab5fe955cf41fbcbe05b0b0bce96a7f851",
          "id": "did:holo:sha256:8dac41353bc4ce9182f5ab1f36d9b27774358ce5899f5322e78694283411d0aa"
        },
        {
          "name": "ask-model",
          "description": "Ask the connected agent's OWN model a question (MCP sampling — the INVERSE direction: a holospace borrows the agent's intelligence). Requires a sampling-capable client.",
          "path": "skills/ask-model/SKILL.md",
          "kappa": "sha256:f607b4a454dd7ba1cd6925f5a00ae04a11086edee295f238e696f779c7cb2ba7",
          "id": "did:holo:sha256:14157e0a9de39b8aede0d564f4fd7ce90492fd9cd6cdecd85c3a115e73fa8665"
        },
        {
          "name": "ask-user",
          "description": "Ask the human, via the agent host, for input (MCP elicitation). Requires an elicitation-capable client.",
          "path": "skills/ask-user/SKILL.md",
          "kappa": "sha256:9430f6fe58c8146e5ac1ecec10fb9e6e8bee8a0b881d8e6ba4dcbc4994f0a88e",
          "id": "did:holo:sha256:628645ff5046e8270819cbcbfdaf175488e54d4bf8d8fdd019c9c276c8729abb"
        },
        {
          "name": "browser-fetch",
          "description": "Fetch a URL through Holo Browser's loading seam and return its content address (κ / did:holo) plus content-type and size, re-derived (Law L5) — the bytes are content-addressed substrate, not a trusted response.",
          "path": "skills/browser-fetch/SKILL.md",
          "kappa": "sha256:230a285f0103b91765c11ea980380402bfb6311d467a4a6e46f583de714539dc",
          "id": "did:holo:sha256:11f8f2f4392c7f60ae6c560ac16e43a461b3fefca0da9e432467d0e7d7979ff5"
        },
        {
          "name": "browser-open",
          "description": "Open a URL in Holo Browser's content-addressed loader and return a self-verifying snapshot: the served/minted κ (a did:holo you re-derive, Law L5), final URL, title, extracted text and links. Accepts holo://κ, ipfs://, ENS .eth and http(s) (a live page is fetched once and minted into a κ).",
          "path": "skills/browser-open/SKILL.md",
          "kappa": "sha256:062ee4c065851445d2328f41dc0e1457ecea65369093b42ed2ad515e7c83a4f0",
          "id": "did:holo:sha256:8cfd00e0790cc9cea811806410fc2a4d88deeb87ecd6adfbdb903b21aba768d4"
        },
        {
          "name": "disclose-for-purpose",
          "description": "Holo Privacy: obtain a W3C Verifiable Presentation that discloses ONLY the personal-data claims the user's standing policy authorizes for a given DPV purpose + recipient (IETF SD-JWT selective disclosure) — and can prove a fact (\"over 18\") without revealing the value behind it. Returns null when nothing is authorized (default-deny). Needs a connected wallet (the Holo Privacy app). Present the result to any tool that handles personal data.",
          "path": "skills/disclose-for-purpose/SKILL.md",
          "kappa": "sha256:a46d6bf1bac6ea64d34cd875d1283a0336885d257035a51761f93d8957e4b326",
          "id": "did:holo:sha256:e8f864d0fa9cdd74a1adf26b39b120d83562061d2ef3e199d1565f74ae552077"
        },
        {
          "name": "holo-rank",
          "description": "Personal, content-addressed PageRank (HoloRank). Given reference edges {rel,from,to,by?,weight?} and a seed (teleport set of did:holo you trust/own), returns a SELF-VERIFYING UOR ranking object. The result is deterministic, so DON'T trust it — re-derive its did (verify_object, Law L5) and/or recompute holo_rank over the same edges to confirm the same κ. Trustless ranking for agents.",
          "path": "skills/holo-rank/SKILL.md",
          "kappa": "sha256:34dc8d300515e873150aa5c24a1bbcb14b64e9007ce0b65741eda8ba508aca30",
          "id": "did:holo:sha256:8044c92a3609f0eee9287292151e2bc979579fd9d64d1ab86f8d4d003ac59400"
        },
        {
          "name": "holo-recommend",
          "description": "One round-trip personal recommendations. Give the apps/did:holo you use ('usage'); the server fetches only YOUR neighbourhood by content address (bounded — taste-aligned reviewers + their picks, not the whole corpus) and ranks it, returning recs (each with a reason) plus a SELF-VERIFYING UOR result you re-derive (Law L5) and can recompute (deterministic). Requires the server to be wired to a review corpus.",
          "path": "skills/holo-recommend/SKILL.md",
          "kappa": "sha256:9e561b83604fb5c8b535bd1b14a6a9b40018fd0f7a7da9acea1d673a95fd3944",
          "id": "did:holo:sha256:3d8fb5569186b26f251d707e7439678837d23f41e0d5fb8a6fcb5bd365090a6a"
        },
        {
          "name": "list-roots",
          "description": "List the file:// roots the agent host has granted access to (MCP roots). Requires a roots-capable client.",
          "path": "skills/list-roots/SKILL.md",
          "kappa": "sha256:61d71ba4573ac92867a8d5fc8e251c1f63be73ed3d76b33a11101977654585b6",
          "id": "did:holo:sha256:e519198424e6b7223c5224e9d6525106cbc9c3e148c95c7ebc3d2072f969843e"
        },
        {
          "name": "read-liberty",
          "description": "Return a self-verifying chapter of On Liberty as a UOR object the agent can re-derive (Law L5). Args: chapter (0=Introduction, 1..5 = the chapters) or find (a phrase; returns the chapter containing it). With no args, returns the book root object.",
          "path": "skills/read-liberty/SKILL.md",
          "kappa": "sha256:06dcf5968a09232b106d07af04f0d252d1bc975602108f38517212b80c7abe25",
