+/// Encode the `Weights` payload AND its random-access `WeightIndex` (ADR-0101,
+/// Stage 2) in ONE pass, so each index entry's `offset` exactly locates that
+/// weight's body within the `Weights` payload. The `Weights` payload format is
+/// `count`, then `{fp, len, body}` per weight (unchanged — [`decode_weights`]
+/// reads it); the index is `count`, then `{fp, body_offset_in_weights_payload,
+/// len}`, decoded by [`crate::weight_index::WeightIndex::decode`].
+fn encode_weights_and_index(weights: &WeightStore) -> (Vec<u8>, Vec<u8>) {
+    let mut wout = Vec::new();
+    let mut iout = Vec::new();
+    wout.extend_from_slice(&(weights.len() as u32).to_le_bytes());
+    iout.extend_from_slice(&(weights.len() as u32).to_le_bytes());
     for (fp, bytes) in weights.entries() {
-        out.extend_from_slice(&fp.0);
-        out.extend_from_slice(&(bytes.len() as u64).to_le_bytes());
-        out.extend_from_slice(bytes);
+        // The body begins right after this entry's fingerprint (32) + len (8) fields.
+        let body_offset = (wout.len() + 32 + 8) as u64;
+        wout.extend_from_slice(&fp.0);
+        wout.extend_from_slice(&(bytes.len() as u64).to_le_bytes());
+        wout.extend_from_slice(bytes);
+        iout.extend_from_slice(&fp.0);
+        iout.extend_from_slice(&body_offset.to_le_bytes());
+        iout.extend_from_slice(&(bytes.len() as u64).to_le_bytes());
     }
-    out
+    (wout, iout)
 }
 
