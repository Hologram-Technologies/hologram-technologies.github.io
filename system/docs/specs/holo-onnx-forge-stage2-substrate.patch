+//! ADR-0101 Stage 2: a compiled archive carries a random-access `WeightIndex` over
+//! its `Weights` section, and the runtime resolves each weight body by its κ on
+//! demand (re-derived, Law L5) — instead of decoding every body into a second
+//! in-RAM `WeightStore`. This proves, on REAL compiler output, that (1) the writer
+//! emits the index, (2) the index offsets correctly locate each body, and (3) the
+//! executor loads + executes correctly via the lazy path.
+
+use hologram_archive::{
+    decode_weights, format::SectionKind, HoloLoader, LazyWeightStore, SliceResolver,
+    WeightFingerprint, WeightIndex,
+};
+use hologram_backend::CpuBackend;
+use hologram_compiler::{compile, BackendKind};
+use hologram_exec::{BufferArena, InferenceSession, InputBuffer};
+use hologram_graph::constant::ConstantEntry;
+use hologram_graph::node::Node;
+use hologram_graph::registry::{DTypeId, ShapeDescriptor};
+use hologram_graph::{Graph, GraphOp, InputSource, OpKind};
+use prism::vocabulary::WittLevel;
+use smallvec::SmallVec;
+
+const DTYPE_F32: u8 = 8;
+
+fn f32_to_le(values: &[f32]) -> Vec<u8> {
+    values.iter().flat_map(|v| v.to_le_bytes()).collect()
+}
+fn le_to_f32(bytes: &[u8]) -> Vec<f32> {
+    bytes
+        .chunks_exact(4)
+        .map(|c| f32::from_le_bytes(c.try_into().unwrap()))
+        .collect()
+}
+
+/// Compile `out = input + C` where `C` is an 8 KiB constant (above the 4 KiB inline
+/// threshold, so it becomes a content-addressed weight in the `Weights` section).
+fn compile_add_const() -> (Vec<u8>, Vec<f32>) {
+    let mut graph = Graph::new();
+    let shape = graph
+        .shape_registry_mut()
+        .intern(ShapeDescriptor::rank1(2048));
+    let cvals: Vec<f32> = (0..2048).map(|i| (i as f32) * 0.25 - 100.0).collect();
+    let cid = graph.constants_mut().insert(ConstantEntry {
+        bytes: f32_to_le(&cvals),
+        dtype: DTypeId(DTYPE_F32),
+        shape,
+    });
+    let x = graph.add_node(Node {
+        op: GraphOp::Input,
+        inputs: SmallVec::new(),
+        output_dtype: DTypeId(DTYPE_F32),
+        output_shape: shape,
+    });
+    graph.add_input(x);
+    let add = graph.add_node(Node {
+        op: GraphOp::Op(OpKind::Add),
+        inputs: SmallVec::from_iter([InputSource::Node(x), InputSource::Constant(cid)]),
+        output_dtype: DTypeId(DTYPE_F32),
+        output_shape: shape,
+    });
+    let out = graph.add_node(Node {
+        op: GraphOp::Output,
+        inputs: SmallVec::from_iter([InputSource::Node(add)]),
+        output_dtype: DTypeId(DTYPE_F32),
+        output_shape: shape,
+    });
+    graph.add_output(out);
+    let compiled = compile(graph, BackendKind::Cpu, WittLevel::W32).unwrap();
+    (compiled.archive, cvals)
+}
+
+#[test]
+fn compiled_archive_carries_a_weight_index() {
+    let (archive, _) = compile_add_const();
+    let plan = HoloLoader::from_bytes(&archive)
+        .unwrap()
+        .into_plan()
+        .unwrap();
+    assert!(
+        plan.section(SectionKind::WeightIndex).is_ok(),
+        "the patched writer must emit a WeightIndex over the Weights section"
+    );
+}
+
+#[test]
+fn lazy_store_resolves_every_compiled_weight_matching_eager() {
+    let (archive, _) = compile_add_const();
+    let plan = HoloLoader::from_bytes(&archive)
+        .unwrap()
+        .into_plan()
+        .unwrap();
+
+    let eager = decode_weights(plan.section(SectionKind::Weights).unwrap()).unwrap();
+    let index = WeightIndex::decode(plan.section(SectionKind::WeightIndex).unwrap()).unwrap();
+    let weights_off = plan.section_ref(SectionKind::Weights).unwrap().offset;
+    let lazy = LazyWeightStore::new(index, weights_off, SliceResolver::new(&archive));
+
+    // Every weight the eager store holds must resolve identically through the lazy
+    // path — same κ, same bytes, re-derived (L5). This validates the index offsets
+    // on real compiler output.
+    let mut checked = 0;
+    for (fp, body) in eager.entries() {
+        assert_eq!(lazy.body_len(fp), Some(body.len() as u64));
+        let got = lazy.body(fp).unwrap().expect("indexed");
+        assert_eq!(&got, body, "lazy body must match eager body");
+        checked += 1;
+    }
+    assert!(
+        checked >= 1,
+        "the 8 KiB constant should be a content-addressed weight"
+    );
+    // An unknown fingerprint resolves to nothing.
+    assert!(lazy
+        .body(&WeightFingerprint::of(b"not a weight in this model"))
+        .unwrap()
+        .is_none());
+}
+
+#[test]
+fn session_loads_and_executes_via_the_lazy_path() {
+    let (archive, cvals) = compile_add_const();
+    let backend: CpuBackend<BufferArena> = CpuBackend::new();
+    let mut session = InferenceSession::load(&archive, backend).unwrap();
+    // input = zeros → output == the constant weight, proving the lazy-resolved
+    // weight bytes reached the pool correctly.
+    let zeros = f32_to_le(&vec![0.0_f32; 2048]);
+    let outputs = session.execute(&[InputBuffer { bytes: &zeros }]).unwrap();
+    assert_eq!(le_to_f32(&outputs[0].bytes), cvals);
+}
