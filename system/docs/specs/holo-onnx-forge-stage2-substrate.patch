@@ -0,0 +1,285 @@
+//! Random-access weight resolution (ADR-0101, Stage 2).
+//!
+//! The `Weights` section is a flat concatenation of `{fingerprint, len, body}` —
+//! to reach weight *N* the eager [`crate::weight::WeightStore`] decodes **every**
+//! body into a `HashMap`, a full second copy of all weights in RAM. The
+//! [`WeightIndex`] section instead records each body's `(offset, len)` within the
+//! `Weights` payload, so a [`LazyWeightStore`] can fetch ONE body by its κ from a
+//! byte-range [`RangeResolver`] — holding only the index resident, never the bodies.
+//!
+//! Every fetched body is **re-derived against its fingerprint before it is returned
+//! (Law L5)**: a range that does not hash back to the κ it was asked for is refused.
+//!
+//! The resolver is the seam to streaming: [`SliceResolver`] reads from a resident
+//! archive buffer (the win there is eliminating the all-bodies `HashMap`); a custom
+//! resolver can fetch ranges from a κ-store / file so the archive itself need not be
+//! resident (true demand-paging).
+
+use alloc::vec::Vec;
+use hashbrown::HashMap;
+
+use crate::error::ArchiveError;
+use crate::weight::WeightFingerprint;
+
+/// The `(offset, len)` of a weight body within the `Weights` section payload.
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub struct WeightSpan {
+    /// Byte offset of the body, relative to the start of the `Weights` payload.
+    pub offset: u64,
+    /// Body length in bytes.
+    pub len: u64,
+}
+
+/// A decoded `WeightIndex`: each weight fingerprint → its span in the `Weights` payload.
+#[derive(Debug, Clone, Default)]
+pub struct WeightIndex {
+    spans: HashMap<WeightFingerprint, WeightSpan>,
+}
+
+impl WeightIndex {
+    /// Decode a `WeightIndex` section payload: `count(u32)` then `count` entries of
+    /// `fingerprint([u8;32]) offset(u64) len(u64)`, little-endian.
+    pub fn decode(bytes: &[u8]) -> Result<Self, ArchiveError> {
+        if bytes.len() < 4 {
+            return Err(ArchiveError::Truncated {
+                needed: 4,
+                actual: bytes.len(),
+            });
+        }
+        let count = u32::from_le_bytes(bytes[..4].try_into().unwrap()) as usize;
+        let mut spans = HashMap::with_capacity(count);
+        let mut cur = 4usize;
+        for _ in 0..count {
+            let end = cur + 32 + 8 + 8;
+            if end > bytes.len() {
+                return Err(ArchiveError::Truncated {
+                    needed: end,
+                    actual: bytes.len(),
+                });
+            }
+            let mut fp = [0u8; 32];
+            fp.copy_from_slice(&bytes[cur..cur + 32]);
+            cur += 32;
+            let offset = u64::from_le_bytes(bytes[cur..cur + 8].try_into().unwrap());
+            cur += 8;
+            let len = u64::from_le_bytes(bytes[cur..cur + 8].try_into().unwrap());
+            cur += 8;
+            spans.insert(WeightFingerprint(fp), WeightSpan { offset, len });
+        }
+        Ok(Self { spans })
+    }
+
+    /// The span of a weight body by fingerprint, if indexed.
+    pub fn get(&self, fp: &WeightFingerprint) -> Option<WeightSpan> {
+        self.spans.get(fp).copied()
+    }
+
+    /// Number of indexed weights.
+    pub fn len(&self) -> usize {
+        self.spans.len()
+    }
+
+    /// Whether the index holds no weights.
+    pub fn is_empty(&self) -> bool {
+        self.spans.is_empty()
+    }
+}
+
+/// Resolves a byte range from wherever the archive lives: a resident slice
+/// ([`SliceResolver`]), or — the streaming case — a κ-store / file fetch.
+pub trait RangeResolver {
+    /// Return the `len` bytes at absolute archive `offset`.
+    fn fetch(&self, offset: u64, len: u64) -> Result<Vec<u8>, ArchiveError>;
+}
+
+/// A [`RangeResolver`] over a resident archive buffer — slices the range, building
+/// no second copy of the weight set.
+pub struct SliceResolver<'a> {
+    bytes: &'a [u8],
+}
+
+impl<'a> SliceResolver<'a> {
+    pub fn new(bytes: &'a [u8]) -> Self {
+        Self { bytes }
+    }
+}
+
+impl RangeResolver for SliceResolver<'_> {
+    fn fetch(&self, offset: u64, len: u64) -> Result<Vec<u8>, ArchiveError> {
+        let start = offset as usize;
+        let end = start.saturating_add(len as usize);
+        self.bytes
+            .get(start..end)
+            .map(<[u8]>::to_vec)
+            .ok_or(ArchiveError::Truncated {
+                needed: end,
+                actual: self.bytes.len(),
+            })
+    }
+}
+
+/// Resolves weight bodies by fingerprint on demand from a [`RangeResolver`], using a
+/// [`WeightIndex`] to locate each body — without ever holding all bodies resident.
+/// Each body is re-derived against its fingerprint before it is returned (Law L5).
+pub struct LazyWeightStore<R: RangeResolver> {
+    index: WeightIndex,
+    /// Absolute offset of the `Weights` payload in the archive (the anchor that
+    /// turns an index-relative span into an absolute range).
+    weights_offset: u64,
+    resolver: R,
+}
+
+impl<R: RangeResolver> LazyWeightStore<R> {
+    /// Build a lazy store from a decoded index, the archive's `Weights` payload
+    /// offset (from `LoadedPlan::section_ref(Weights).offset`), and a resolver.
+    pub fn new(index: WeightIndex, weights_offset: u64, resolver: R) -> Self {
+        Self {
+            index,
+            weights_offset,
+            resolver,
+        }
+    }
+
+    /// Number of indexed weights.
+    pub fn len(&self) -> usize {
+        self.index.len()
+    }
+
+    /// Whether the store indexes no weights.
+    pub fn is_empty(&self) -> bool {
+        self.index.is_empty()
+    }
+
+    /// The body length for a fingerprint, from the index alone — no body is read.
+    /// This is what lets load-time sizing avoid touching weight bytes.
+    pub fn body_len(&self, fp: &WeightFingerprint) -> Option<u64> {
+        self.index.get(fp).map(|s| s.len)
+    }
+
+    /// Resolve and return a weight body by fingerprint, re-derived against `fp`
+    /// (Law L5). `Ok(None)` if the fingerprint is not indexed; an error if the
+    /// range can't be fetched or the bytes do not hash back to `fp`.
+    pub fn body(&self, fp: &WeightFingerprint) -> Result<Option<Vec<u8>>, ArchiveError> {
+        let Some(span) = self.index.get(fp) else {
+            return Ok(None);
+        };
+        let bytes = self
+            .resolver
+            .fetch(self.weights_offset + span.offset, span.len)?;
+        // Law L5: a byte that does not re-derive to the κ it was fetched for is refused.
+        if WeightFingerprint::of(&bytes) != *fp {
+            return Err(ArchiveError::ChecksumMismatch);
+        }
+        Ok(Some(bytes))
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::weight::WeightStore;
+    use crate::writer::HoloWriter;
+
+    /// Build a real archive with a few weights and return (archive bytes, fingerprints).
+    fn archive_with_weights(bodies: &[&[u8]]) -> (Vec<u8>, Vec<WeightFingerprint>) {
+        let mut store = WeightStore::new();
+        let fps: Vec<WeightFingerprint> = bodies.iter().map(|b| store.insert(b.to_vec())).collect();
+        let mut w = HoloWriter::new();
+        w.set_weights(store);
+        (w.finish().expect("finish archive"), fps)
+    }
+
+    fn lazy_over<'a>(archive: &'a [u8]) -> LazyWeightStore<SliceResolver<'a>> {
+        let plan = crate::loader::HoloLoader::from_bytes(archive)
+            .expect("load")
+            .into_plan()
+            .expect("plan");
+        let idx = WeightIndex::decode(
+            plan.section(crate::format::SectionKind::WeightIndex)
+                .expect("weight index present"),
+        )
+        .expect("decode index");
+        let off = plan
+            .section_ref(crate::format::SectionKind::Weights)
+            .expect("weights section")
+            .offset;
+        LazyWeightStore::new(idx, off, SliceResolver::new(archive))
+    }
+
+    #[test]
+    fn lazy_resolves_each_weight_by_kappa_matching_eager() {
+        let bodies: [&[u8]; 3] = [b"the first weight", &[0x7u8; 4096], b"third"];
+        let (archive, fps) = archive_with_weights(&bodies);
+
+        // Eager decode for the reference bytes.
+        let plan = crate::loader::HoloLoader::from_bytes(&archive)
+            .unwrap()
+            .into_plan()
+            .unwrap();
+        let eager = crate::writer::decode_weights(
+            plan.section(crate::format::SectionKind::Weights).unwrap(),
+        )
+        .unwrap();
+
+        let lazy = lazy_over(&archive);
+        assert_eq!(lazy.len(), bodies.len());
+        for (fp, body) in fps.iter().zip(bodies.iter()) {
+            // length from the index alone (no body read)
+            assert_eq!(lazy.body_len(fp), Some(body.len() as u64));
+            // body resolved on demand, re-derived (L5), equals the eager body
+            let got = lazy.body(fp).unwrap().expect("body present");
+            assert_eq!(&got[..], *body);
+            assert_eq!(&got[..], eager.get(*fp).unwrap());
+        }
+    }
+
+    #[test]
+    fn lazy_refuses_a_tampered_range_l5() {
+        let bodies: [&[u8]; 1] = [b"trusted weight body"];
+        let (mut archive, fps) = archive_with_weights(&bodies);
+
+        // Corrupt the weight body in place: find the Weights payload and flip a byte
+        // inside the body (after the count + fp + len header of entry 0).
+        let plan = crate::loader::HoloLoader::from_bytes(&archive)
+            .unwrap()
+            .into_plan()
+            .unwrap();
+        let woff = plan
+            .section_ref(crate::format::SectionKind::Weights)
+            .unwrap()
+            .offset as usize;
+        drop(plan);
+        let body0 = woff + 4 + 32 + 8; // count(4) + fp(32) + len(8)
+        archive[body0] ^= 0xFF;
+
+        // Re-derivation must refuse it (the footer also breaks, so build the lazy
+        // store with the unchecked loader to isolate the weight-level L5 check).
+        let plan = crate::loader::HoloLoader::from_bytes_unchecked(&archive)
+            .unwrap()
+            .into_plan()
+            .unwrap();
+        let idx = WeightIndex::decode(
+            plan.section(crate::format::SectionKind::WeightIndex)
+                .unwrap(),
+        )
+        .unwrap();
+        let off = plan
+            .section_ref(crate::format::SectionKind::Weights)
+            .unwrap()
+            .offset;
+        let lazy = LazyWeightStore::new(idx, off, SliceResolver::new(&archive));
+        assert!(
+            matches!(lazy.body(&fps[0]), Err(ArchiveError::ChecksumMismatch)),
+            "a tampered weight range must be refused (L5)"
+        );
+    }
+
+    #[test]
+    fn unindexed_fingerprint_is_none() {
+        let (archive, _) = archive_with_weights(&[b"only weight"]);
+        let lazy = lazy_over(&archive);
+        let phantom = WeightFingerprint::of(b"never stored");
+        assert!(lazy.body(&phantom).unwrap().is_none());
+        assert_eq!(lazy.body_len(&phantom), None);
+    }
+}
